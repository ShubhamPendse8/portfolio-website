{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@content/*": ["content/*"]
    },
    "allowJs": true,
    "resolveJsonModule": true
  },
  "include": [".astro/types.d.ts", "**/*.ts", "**/*.astro", "**/*.tsx", "**/*.jsx", "src/env.d.ts"]
}
