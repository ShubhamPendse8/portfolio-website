---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const link = (p: string) => `${base}${p}`;
const current = Astro.url.pathname.replace(base, '') || '/';
const isActive = (href: string) => {
  if (href === '/') return current === '/' || current === '';
  return current.startsWith(href);
};

const items = [
  { href: '/', label: 'Home' },
  { href: '/work', label: 'Work' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
---
<header class="nav" data-nav>
  <div class="nav__inner glass-strong">
    <a href={link('/')} class="nav__brand" data-testid="nav-brand">
      <span class="nav__brand-mark" aria-hidden="true">
        <svg viewBox="0 0 32 32" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6">
          <path d="M6 22 L16 6 L26 22" />
          <path d="M11 22 L16 14 L21 22" opacity="0.55" />
        </svg>
      </span>
      <span class="nav__brand-text">
        <span class="nav__brand-name">Shubham Pendse</span>
        <span class="nav__brand-role">Designer, Mumbai</span>
      </span>
    </a>

    <nav class="nav__links" aria-label="Primary">
      {items.map((it) => (
        <a
          href={link(it.href)}
          class:list={['nav__link', isActive(it.href) && 'is-active']}
          data-testid={`nav-link-${it.label.toLowerCase()}`}
        >
          {it.label}
        </a>
      ))}
    </nav>

    <div class="nav__actions">
      <button
        class="nav__cmd"
        type="button"
        data-cmd-open
        aria-label="Open command menu"
        data-testid="nav-cmd-open"
      >
        <span>Menu</span>
        <kbd>⌘K</kbd>
      </button>
      <button
        class="nav__theme"
        type="button"
        data-theme-toggle
        aria-label="Toggle theme"
        data-testid="theme-toggle"
      >
        <svg class="nav__theme-icon nav__theme-icon--dark" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z" stroke-linejoin="round"/>
        </svg>
        <svg class="nav__theme-icon nav__theme-icon--light" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 3v2M12 19v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M3 12h2M19 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4"/>
        </svg>
      </button>
      <button
        class="nav__burger"
        type="button"
        data-mobile-toggle
        aria-label="Open menu"
        aria-expanded="false"
        data-testid="mobile-menu-toggle"
      >
        <span></span><span></span>
      </button>
    </div>
  </div>

  <div class="nav__mobile glass-strong" data-mobile-panel hidden>
    <nav aria-label="Mobile primary">
      {items.map((it) => (
        <a
          href={link(it.href)}
          class:list={['nav__mobile-link', isActive(it.href) && 'is-active']}
          data-testid={`mobile-nav-link-${it.label.toLowerCase()}`}
        >
          {it.label}
          <span aria-hidden="true">→</span>
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    top: 14px;
    left: 0;
    right: 0;
    z-index: 40;
    padding: 0 var(--gutter);
    padding-top: env(safe-area-inset-top);
  }
  .nav__inner {
    max-width: var(--container);
    margin: 0 auto;
    height: var(--nav-height);
    padding: 0 18px 0 22px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    border-radius: 999px;
    box-shadow: var(--shadow);
    transition: background var(--dur) var(--ease),
                border-color var(--dur) var(--ease),
                box-shadow var(--dur) var(--ease),
                backdrop-filter var(--dur) var(--ease);
  }
  /* When scrolled, boost opacity so content underneath is not readable through the glass */
  .nav.is-scrolled .nav__inner {
    background: rgba(10, 10, 12, 0.94);
    backdrop-filter: blur(30px) saturate(160%);
    -webkit-backdrop-filter: blur(30px) saturate(160%);
    border-color: rgba(255, 255, 255, 0.14);
  }
  :root[data-theme='light'] .nav.is-scrolled .nav__inner {
    background: rgba(253, 250, 244, 0.95);
    border-color: rgba(20, 20, 15, 0.14);
  }
  @media (prefers-reduced-transparency: reduce) {
    .nav.is-scrolled .nav__inner { background: var(--surface); backdrop-filter: none; -webkit-backdrop-filter: none; }
  }
  .nav__brand {
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--text);
    font-family: var(--font-body);
    line-height: 1;
  }
  .nav__brand-mark {
    width: 34px; height: 34px;
    display: grid; place-items: center;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--accent-soft);
    color: var(--accent);
    transition: transform var(--dur) var(--ease);
  }
  .nav__brand:hover .nav__brand-mark { transform: rotate(-6deg); }
  .nav__brand-text { display: flex; flex-direction: column; gap: 3px; }
  .nav__brand-name { font-size: 0.94rem; font-weight: 600; letter-spacing: -0.01em; }
  .nav__brand-role { font-size: 0.72rem; color: var(--text-muted); letter-spacing: 0.02em; }

  .nav__links {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .nav__link {
    padding: 8px 14px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-muted);
    border-radius: 999px;
    transition: color var(--dur-fast) var(--ease), background var(--dur-fast) var(--ease);
  }
  .nav__link:hover { color: var(--text); background: var(--surface); }
  .nav__link.is-active { color: var(--accent); }
  .nav__link.is-active::after {
    content: '';
    display: block;
    height: 2px;
    width: 12px;
    background: var(--accent);
    border-radius: 2px;
    margin: 3px auto 0;
  }

  .nav__actions { display: flex; align-items: center; gap: 8px; }

  .nav__cmd {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text-muted);
    border-radius: 999px;
    padding: 8px 12px;
    font-family: inherit;
    font-size: 0.82rem;
    cursor: pointer;
    transition: color var(--dur) var(--ease), border-color var(--dur) var(--ease);
  }
  .nav__cmd:hover { color: var(--text); border-color: var(--border-strong); }
  .nav__cmd kbd {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 2px 6px;
    border-radius: 4px;
    background: rgba(255,255,255,0.08);
    color: var(--text);
    border: 1px solid var(--border);
  }

  .nav__theme {
    width: 40px; height: 40px;
    display: grid; place-items: center;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text-muted);
    border-radius: 50%;
    cursor: pointer;
    transition: color var(--dur) var(--ease), border-color var(--dur) var(--ease), transform var(--dur) var(--ease);
  }
  .nav__theme:hover { color: var(--accent); border-color: var(--accent); transform: rotate(15deg); }
  .nav__theme-icon { transition: opacity var(--dur) var(--ease); }
  :root[data-theme='dark'] .nav__theme-icon--light { display: none; }
  :root[data-theme='light'] .nav__theme-icon--dark { display: none; }

  .nav__burger {
    display: none;
    width: 40px; height: 40px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 50%;
    color: var(--text);
    cursor: pointer;
    align-items: center; justify-content: center;
    flex-direction: column; gap: 4px;
  }
  .nav__burger span {
    width: 15px; height: 1.5px; background: currentColor;
    transition: transform var(--dur) var(--ease), opacity var(--dur) var(--ease);
  }
  .nav__burger[aria-expanded='true'] span:first-child { transform: translateY(3px) rotate(45deg); }
  .nav__burger[aria-expanded='true'] span:last-child { transform: translateY(-3px) rotate(-45deg); }

  .nav__mobile {
    max-width: var(--container);
    margin: 10px auto 0;
    border-radius: var(--radius-lg);
    padding: 12px;
    box-shadow: var(--shadow);
  }
  .nav__mobile[hidden] { display: none; }
  .nav__mobile nav { display: flex; flex-direction: column; }
  .nav__mobile-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 18px;
    font-family: var(--font-display);
    font-size: 1.4rem;
    letter-spacing: -0.02em;
    color: var(--text);
    border-bottom: 1px solid var(--border);
  }
  .nav__mobile-link:last-child { border-bottom: 0; }
  .nav__mobile-link.is-active { color: var(--accent); }
  .nav__mobile-link span { color: var(--text-muted); }

  @media (max-width: 900px) {
    .nav__links { display: none; }
    .nav__cmd { display: none; }
    .nav__burger { display: inline-flex; }
    .nav__brand-role { display: none; }
  }
  @media (max-width: 480px) {
    .nav__inner { padding: 0 12px 0 14px; gap: 8px; }
    .nav__brand-name { font-size: 0.86rem; }
  }
</style>

<script>
  // Theme toggle
  const root = document.documentElement;
  const btns = document.querySelectorAll('[data-theme-toggle]');
  btns.forEach((btn) =>
    btn.addEventListener('click', () => {
      const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      root.setAttribute('data-theme', next);
      try { localStorage.setItem('theme', next); } catch (e) {}
    })
  );

  // Mobile menu
  const toggle = document.querySelector('[data-mobile-toggle]');
  const panel = document.querySelector('[data-mobile-panel]');
  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    if (expanded) {
      panel?.setAttribute('hidden', '');
      toggle.setAttribute('aria-label', 'Open menu');
    } else {
      panel?.removeAttribute('hidden');
      toggle.setAttribute('aria-label', 'Close menu');
    }
  });
  // Close mobile menu on link click
  document.querySelectorAll('[data-mobile-panel] a').forEach((a) =>
    a.addEventListener('click', () => {
      panel?.setAttribute('hidden', '');
      toggle?.setAttribute('aria-expanded', 'false');
    })
  );

  // Nav elevation on scroll — robust to whichever element is the scroll root
  const nav = document.querySelector('[data-nav]');
  const getScrollTop = () =>
    window.scrollY ||
    (document.scrollingElement && document.scrollingElement.scrollTop) ||
    document.documentElement.scrollTop ||
    document.body.scrollTop ||
    0;
  const onScroll = () => {
    if (getScrollTop() > 24) nav?.classList.add('is-scrolled');
    else nav?.classList.remove('is-scrolled');
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  document.addEventListener('scroll', onScroll, { passive: true, capture: true });
  onScroll();
</script>
