---
// A page-wide image lightbox activated by data-lightbox attribute on images.
---
<div class="lbx" data-lightbox-root hidden role="dialog" aria-modal="true" aria-label="Image viewer" data-testid="lightbox">
  <button class="lbx__close" data-lbx-close aria-label="Close image viewer" data-testid="lightbox-close">
    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 6l12 12M18 6L6 18"/></svg>
  </button>
  <button class="lbx__nav lbx__nav--prev" data-lbx-prev aria-label="Previous image" data-testid="lightbox-prev">
    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M15 6l-6 6 6 6"/></svg>
  </button>
  <button class="lbx__nav lbx__nav--next" data-lbx-next aria-label="Next image" data-testid="lightbox-next">
    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 6l6 6-6 6"/></svg>
  </button>
  <div class="lbx__stage" data-lbx-stage>
    <img data-lbx-img alt="" />
  </div>
  <div class="lbx__caption" data-lbx-caption></div>
  <div class="lbx__counter" data-lbx-counter></div>
</div>

<style>
  .lbx {
    position: fixed;
    inset: 0;
    z-index: 90;
    background: rgba(3,3,3,0.94);
    backdrop-filter: blur(8px);
    display: grid;
    place-items: center;
    grid-template-rows: 1fr auto;
    padding: clamp(20px, 4vw, 60px);
    animation: lbxIn 220ms var(--ease);
  }
  @keyframes lbxIn { from { opacity: 0; } to { opacity: 1; } }
  .lbx[hidden] { display: none; }
  .lbx__stage {
    display: grid;
    place-items: center;
    width: 100%; height: 100%;
    max-height: 84vh;
  }
  .lbx__stage img {
    max-width: 100%;
    max-height: 84vh;
    width: auto; height: auto;
    object-fit: contain;
    border-radius: 8px;
    box-shadow: 0 20px 80px rgba(0,0,0,0.6);
  }
  .lbx__close {
    position: absolute;
    top: clamp(16px, 3vw, 30px);
    right: clamp(16px, 3vw, 30px);
    width: 44px; height: 44px;
    display: grid; place-items: center;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.14);
    color: #fff;
    border-radius: 50%;
    cursor: pointer;
    transition: background var(--dur) var(--ease), transform var(--dur) var(--ease);
  }
  .lbx__close:hover { background: var(--accent); color: #0a0403; transform: rotate(90deg); }
  .lbx__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 48px; height: 48px;
    display: grid; place-items: center;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    color: #fff;
    border-radius: 50%;
    cursor: pointer;
    transition: background var(--dur) var(--ease);
  }
  .lbx__nav:hover { background: var(--accent); color: #0a0403; }
  .lbx__nav--prev { left: clamp(12px, 3vw, 30px); }
  .lbx__nav--next { right: clamp(12px, 3vw, 30px); }
  .lbx__caption {
    color: rgba(255,255,255,0.72);
    font-size: 0.9rem;
    text-align: center;
    padding-top: 16px;
    max-width: 800px;
    margin: 0 auto;
  }
  .lbx__counter {
    color: rgba(255,255,255,0.4);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-align: center;
    margin-top: 6px;
  }
  @media (max-width: 640px) {
    .lbx__nav { width: 40px; height: 40px; }
  }
</style>

<script>
  const root = document.querySelector('[data-lightbox-root]');
  const imgEl = root?.querySelector('[data-lbx-img]');
  const capEl = root?.querySelector('[data-lbx-caption]');
  const countEl = root?.querySelector('[data-lbx-counter]');
  const stage = root?.querySelector('[data-lbx-stage]');
  let images = [];
  let index = 0;

  const collect = () => Array.from(document.querySelectorAll('img[data-lightbox]'));

  const show = (i) => {
    if (!images.length || !imgEl) return;
    index = (i + images.length) % images.length;
    const src = images[index];
    imgEl.src = src.currentSrc || src.src;
    imgEl.alt = src.alt || '';
    if (capEl) capEl.textContent = src.alt || '';
    if (countEl) countEl.textContent = (index + 1) + ' / ' + images.length;
  };

  const open = (el) => {
    images = collect();
    const idx = images.indexOf(el);
    if (idx === -1) return;
    root?.removeAttribute('hidden');
    document.body.style.overflow = 'hidden';
    show(idx);
  };
  const close = () => {
    root?.setAttribute('hidden', '');
    document.body.style.overflow = '';
  };

  document.addEventListener('click', (e) => {
    const t = e.target;
    const img = t.closest && t.closest('img[data-lightbox]');
    if (img) { e.preventDefault(); open(img); }
  });

  root?.querySelector('[data-lbx-close]')?.addEventListener('click', close);
  root?.querySelector('[data-lbx-prev]')?.addEventListener('click', () => show(index - 1));
  root?.querySelector('[data-lbx-next]')?.addEventListener('click', () => show(index + 1));
  root?.addEventListener('click', (e) => {
    if (e.target === root || e.target === stage) close();
  });

  document.addEventListener('keydown', (e) => {
    if (root?.hasAttribute('hidden')) return;
    if (e.key === 'Escape') close();
    else if (e.key === 'ArrowLeft') show(index - 1);
    else if (e.key === 'ArrowRight') show(index + 1);
  });

  // Touch swipe
  let touchX = 0;
  stage?.addEventListener('touchstart', (e) => { touchX = e.touches[0].clientX; }, { passive: true });
  stage?.addEventListener('touchend', (e) => {
    const dx = e.changedTouches[0].clientX - touchX;
    if (Math.abs(dx) > 50) show(index + (dx < 0 ? 1 : -1));
  });
</script>
