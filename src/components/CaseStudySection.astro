---
import type { ProjectSection } from '../lib/content';
export interface Props { section: ProjectSection; }
const { section } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const resolve = (p: string) => (p && !p.startsWith('http') ? `${base}${p.startsWith('/') ? '' : '/'}${p}` : p);
---
{section.type === 'rich_text' && (
  <div class="cs cs--text">
    {section.heading && <h2 class="cs__heading">{section.heading}</h2>}
    <p class="cs__body">{section.body}</p>
  </div>
)}

{section.type === 'image_full' && section.image && (
  <figure class="cs cs--image-full">
    {section.heading && <h2 class="cs__heading">{section.heading}</h2>}
    <img
      src={resolve(section.image)}
      alt={section.alt || ''}
      data-lightbox
      loading="lazy"
      decoding="async"
    />
    {section.caption && <figcaption class="cs__caption">{section.caption}</figcaption>}
  </figure>
)}

{section.type === 'text_image' && section.image && (
  <div class:list={['cs', 'cs--text-image', section.image_position === 'left' && 'cs--reverse']}>
    <div class="cs__text">
      {section.heading && <h2 class="cs__heading">{section.heading}</h2>}
      <p class="cs__body">{section.body}</p>
    </div>
    <figure class="cs__figure">
      <img src={resolve(section.image)} alt={section.alt || ''} data-lightbox loading="lazy" />
    </figure>
  </div>
)}

{section.type === 'image_pair' && section.images && (
  <div class="cs cs--pair">
    {section.heading && <h2 class="cs__heading">{section.heading}</h2>}
    <div class="cs__pair-grid">
      {section.images.map((img: any) => (
        <figure>
          <img src={resolve(img.src)} alt={img.alt || ''} data-lightbox loading="lazy" />
        </figure>
      ))}
    </div>
  </div>
)}

{section.type === 'gallery' && section.images && (
  <div class="cs cs--gallery">
    {section.heading && <h2 class="cs__heading">{section.heading}</h2>}
    <div class="cs__gallery-grid">
      {section.images.map((img: any) => (
        <figure class="cs__gallery-item">
          <img src={resolve(img.src)} alt={img.alt || ''} data-lightbox loading="lazy" />
        </figure>
      ))}
    </div>
  </div>
)}

{section.type === 'before_after' && section.before && section.after && (
  <div class="cs cs--ba">
    {section.heading && <h2 class="cs__heading">{section.heading}</h2>}
    <div class="cs__ba-grid">
      <figure>
        <span class="cs__ba-label">Before</span>
        <img src={resolve(section.before.src)} alt={section.before.alt || 'Before'} data-lightbox loading="lazy" />
      </figure>
      <figure>
        <span class="cs__ba-label">After</span>
        <img src={resolve(section.after.src)} alt={section.after.alt || 'After'} data-lightbox loading="lazy" />
      </figure>
    </div>
    {section.caption && <figcaption class="cs__caption">{section.caption}</figcaption>}
  </div>
)}

{section.type === 'video' && (
  <div class="cs cs--video">
    {section.heading && <h2 class="cs__heading">{section.heading}</h2>}
    {section.url ? (
      <div class="cs__video-embed">
        <iframe
          src={section.url}
          title={section.heading || 'Video'}
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen
        ></iframe>
      </div>
    ) : section.file ? (
      <video src={resolve(section.file)} poster={section.poster ? resolve(section.poster) : undefined} controls preload="metadata"></video>
    ) : null}
  </div>
)}

{section.type === 'outcome' && (
  <div class="cs cs--outcome">
    <span class="eyebrow">{section.heading || 'Outcome'}</span>
    <p class="cs__outcome-body">{section.body}</p>
  </div>
)}

<style>
  .cs { margin: clamp(48px, 8vw, 100px) 0; }
  .cs__heading {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 2.8vw, 2.4rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    margin-bottom: 20px;
    line-height: 1.1;
  }
  @media (max-width: 640px) {
    .cs { margin: 40px 0; }
    .cs__heading { margin-bottom: 14px; }
    .cs__body { font-size: 0.98rem; line-height: 1.65; }
    .cs--outcome { padding: 26px 22px; }
    .cs__outcome-body { font-size: 1.15rem; margin-top: 10px; }
  }
  .cs__body { font-size: 1.05rem; color: var(--text-muted); line-height: 1.75; max-width: 720px; }
  .cs__caption { color: var(--text-dim); font-size: 0.85rem; margin-top: 14px; }

  .cs--image-full img {
    width: 100%;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    cursor: zoom-in;
  }

  .cs--text-image {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: clamp(24px, 4vw, 60px);
    align-items: center;
  }
  .cs--text-image.cs--reverse { direction: rtl; }
  .cs--text-image.cs--reverse > * { direction: ltr; }
  .cs--text-image img { width: 100%; border-radius: var(--radius); border: 1px solid var(--border); cursor: zoom-in; }
  @media (max-width: 780px) { .cs--text-image { grid-template-columns: 1fr; } }

  .cs__pair-grid, .cs__ba-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .cs__pair-grid img, .cs__ba-grid img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    cursor: zoom-in;
  }
  @media (max-width: 640px) {
    .cs__pair-grid, .cs__ba-grid { grid-template-columns: 1fr; }
  }
  .cs__ba-label {
    display: inline-block;
    padding: 4px 10px;
    background: var(--accent);
    color: #0a0403;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border-radius: 4px;
    margin-bottom: 8px;
  }
  .cs__ba-grid figure { display: flex; flex-direction: column; }

  .cs__gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .cs__gallery-item {
    overflow: hidden;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--surface-2);
    aspect-ratio: 1 / 1;
  }
  .cs__gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    cursor: zoom-in;
    transition: transform 800ms var(--ease);
  }
  .cs__gallery-item:hover img { transform: scale(1.04); }
  @media (max-width: 1024px) {
    .cs__gallery-grid { grid-template-columns: repeat(3, 1fr); gap: 14px; }
  }
  @media (max-width: 640px) {
    .cs__gallery-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
  }

  .cs--video video, .cs__video-embed {
    width: 100%;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .cs__video-embed {
    aspect-ratio: 16 / 9;
    background: #000;
  }
  .cs__video-embed iframe { width: 100%; height: 100%; border: 0; }

  .cs--outcome {
    padding: clamp(32px, 5vw, 56px);
    background: linear-gradient(135deg, var(--accent-soft), transparent 65%), var(--surface);
    border: 1px solid var(--accent);
    border-radius: var(--radius-lg);
  }
  .cs__outcome-body {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.6vw, 2rem);
    line-height: 1.3;
    letter-spacing: -0.015em;
    color: var(--text);
    margin-top: 18px;
    font-weight: 350;
  }
</style>
