---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { home, site, getFeaturedProjects } from '../lib/content';

const featured = getFeaturedProjects().slice(0, 6);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const link = (p: string) => `${base}${p}`;

const glyphSVG: Record<string, string> = {
  brand:   '<path d="M4 6h16M4 12h10M4 18h16"/><circle cx="19" cy="12" r="2.4"/>',
  social:  '<circle cx="6" cy="6" r="2.4"/><circle cx="18" cy="6" r="2.4"/><circle cx="6" cy="18" r="2.4"/><circle cx="18" cy="18" r="2.4"/><path d="M8 7l8 10M16 7l-8 10"/>',
  uiux:    '<rect x="3" y="4" width="18" height="14" rx="2"/><path d="M3 9h18M8 4v14"/>',
  deck:    '<rect x="3" y="4" width="18" height="12" rx="2"/><path d="M8 20h8M12 16v4"/><path d="M7 8h10M7 12h6"/>',
  print:   '<rect x="6" y="9" width="12" height="8" rx="1"/><path d="M6 9V4h12v5M8 17v3h8v-3"/>',
  motion:  '<path d="M4 12h16"/><path d="M4 8l4 4-4 4"/><circle cx="18" cy="12" r="2.2"/>',
};
---
<BaseLayout title="Portfolio" description={site.seo.description} bodyClass="page-home">

  <!-- HERO -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__text reveal">
        <span class="eyebrow">{home.hero.eyebrow}</span>
        <h1 class="hero__heading">
          Design that clears <br/>the noise <em>and carries</em> <br/>the message.
        </h1>
        <p class="hero__sub lead">{home.hero.subheading}</p>

        <div class="hero__ctas">
          <a class="btn btn--primary" href={link(home.hero.primary_cta.url)} data-testid="hero-cta-work">
            {home.hero.primary_cta.label} <span class="arrow">→</span>
          </a>
          <a class="btn btn--ghost" href={link(home.hero.secondary_cta.url)} data-testid="hero-cta-contact">
            {home.hero.secondary_cta.label}
          </a>
          <a class="hero__resume" href={link(home.hero.resume_cta.url)} target="_blank" rel="noopener" data-testid="hero-cta-resume">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 4v12m0 0-4-4m4 4 4-4M4 20h16"/></svg>
            {home.hero.resume_cta.label}
          </a>
        </div>

        <div class="hero__meta">
          <span class="hero__meta-item">
            <span class="hero__meta-dot" aria-hidden="true"></span>
            {site.availability}
          </span>
          <span class="hero__meta-sep">·</span>
          <span>{site.location}</span>
        </div>
      </div>

      <div class="hero__visual reveal">
        <div class="hero__frame">
          <div class="hero__grid" aria-hidden="true"></div>
          <div class="hero__handle hero__handle--tl" aria-hidden="true"></div>
          <div class="hero__handle hero__handle--tr" aria-hidden="true"></div>
          <div class="hero__handle hero__handle--bl" aria-hidden="true"></div>
          <div class="hero__handle hero__handle--br" aria-hidden="true"></div>
          <img
            src={link(site.avatar)}
            alt="Portrait illustration of Shubham Pendse"
            class="hero__avatar"
            width="720"
            height="900"
            loading="eager"
            decoding="async"
          />
          <div class="hero__caption glass">
            <span class="mono hero__caption-label">01 · portrait.png</span>
            <span class="hero__caption-line"></span>
            <span class="mono hero__caption-scale">100%</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Ticker -->
    <div class="ticker" aria-hidden="true">
      <div class="ticker__track">
        {[...site.expertise_ticker, ...site.expertise_ticker, ...site.expertise_ticker].map((t) => (
          <span class="ticker__item">
            <span class="ticker__dot"></span>
            {t}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- CAPABILITIES -->
  <section class="section" id="capabilities">
    <div class="container">
      <div class="section__head reveal">
        <span class="eyebrow">What I do</span>
        <h2 class="section-title">Six disciplines. <em>One eye.</em></h2>
        <p class="lead" style="max-width: 640px; margin-top: 18px;">
          Design that has to work as a system, not a single asset. Whether it's a brand's voice or a product's interface — the fundamentals are the same.
        </p>
      </div>

      <div class="cap-grid">
        {home.capabilities.map((c: any, i: number) => (
          <article class="cap reveal" style={`--stagger:${i * 80}ms`} data-testid={`capability-${c.glyph}`}>
            <div class="cap__glyph" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" set:html={glyphSVG[c.glyph] || ''} />
            </div>
            <div class="cap__num">{String(i + 1).padStart(2, '0')}</div>
            <h3 class="cap__title">{c.title}</h3>
            <p class="cap__body">{c.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- SELECTED WORK -->
  <section class="section section--work" id="work">
    <div class="container">
      <div class="work__head reveal">
        <div>
          <span class="eyebrow">Selected work</span>
          <h2 class="section-title">Recent projects <br/><em>and case studies.</em></h2>
        </div>
        <a class="btn btn--ghost" href={link('/work')} data-testid="home-view-all-work">
          View all work <span class="arrow">→</span>
        </a>
      </div>

      <div class="work__grid">
        {featured.map((p, i) => (
          <div
            class:list={['work__cell', i === 0 && 'work__cell--hero']}
            style={`--stagger:${i * 90}ms`}
          >
            <ProjectCard project={p} variant={i === 0 ? 'featured' : 'standard'} index={i} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ABOUT PREVIEW -->
  <section class="section section--about-preview">
    <div class="container about-prev">
      <div class="about-prev__col reveal">
        <span class="eyebrow">About</span>
        <h2 class="section-title">{home.about_preview.heading}</h2>
      </div>
      <div class="about-prev__col reveal" style="--stagger: 100ms;">
        <p class="lead">{home.about_preview.body}</p>
        <a class="btn btn--ghost" href={link(home.about_preview.cta.url)} style="margin-top: 24px;" data-testid="about-preview-cta">
          {home.about_preview.cta.label} <span class="arrow">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="section section--cta">
    <div class="container">
      <div class="finalcta glass-strong reveal">
        <div class="finalcta__inner">
          <div class="finalcta__text">
            <span class="eyebrow">Let's build</span>
            <h2 class="finalcta__heading">{home.final_cta.heading}</h2>
            <p class="lead">{home.final_cta.body}</p>
          </div>
          <div class="finalcta__ctas">
            <a class="btn btn--primary" href={link(home.final_cta.primary.url)} data-testid="final-cta-primary">
              {home.final_cta.primary.label} <span class="arrow">→</span>
            </a>
            <a class="btn btn--ghost" href={link(home.final_cta.secondary.url)} data-testid="final-cta-secondary">
              {home.final_cta.secondary.label}
            </a>
          </div>
        </div>
        <div class="finalcta__decor" aria-hidden="true">
          <svg viewBox="0 0 200 200" width="200" height="200" fill="none" stroke="currentColor" stroke-width="0.8" opacity="0.14">
            <circle cx="100" cy="100" r="80"/>
            <circle cx="100" cy="100" r="60"/>
            <circle cx="100" cy="100" r="40"/>
            <line x1="20" y1="100" x2="180" y2="100"/>
            <line x1="100" y1="20" x2="100" y2="180"/>
          </svg>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero { padding-top: 40px; }
  .hero__inner {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: clamp(30px, 5vw, 80px);
    align-items: center;
    min-height: 78vh;
  }
  .hero__text { padding: 20px 0; }
  .hero__heading {
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 6.2vw, 5.6rem);
    line-height: 1.02;
    letter-spacing: -0.035em;
    margin: 22px 0 22px;
    font-weight: 350;
  }
  .hero__heading em { color: var(--accent); font-style: italic; font-weight: 350; }
  .hero__sub { max-width: 540px; color: var(--text-muted); }
  .hero__ctas {
    display: flex; flex-wrap: wrap; gap: 12px; align-items: center;
    margin-top: 34px;
  }
  .hero__resume {
    display: inline-flex; gap: 8px; align-items: center;
    padding: 8px 4px;
    color: var(--text-muted);
    font-size: 0.88rem;
    border-bottom: 1px dashed var(--border-strong);
    transition: color var(--dur) var(--ease), border-color var(--dur) var(--ease);
  }
  .hero__resume:hover { color: var(--accent); border-color: var(--accent); }

  .hero__meta {
    display: flex; align-items: center; gap: 10px;
    margin-top: 28px;
    color: var(--text-muted);
    font-size: 0.86rem;
  }
  .hero__meta-item { display: inline-flex; align-items: center; gap: 8px; }
  .hero__meta-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: #22c55e; box-shadow: 0 0 0 4px rgba(34,197,94,0.18);
    animation: pulse 2.6s ease-out infinite;
  }
  @keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
  .hero__meta-sep { color: var(--text-dim); }

  /* Hero visual */
  .hero__visual {
    position: relative;
    display: grid; place-items: center;
    aspect-ratio: 1 / 1.05;
    max-width: 560px;
    justify-self: end;
    width: 100%;
  }
  .hero__frame {
    position: relative;
    width: 100%; height: 100%;
    display: grid; place-items: center;
    padding: 30px;
  }
  .hero__grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: radial-gradient(circle at center, black 40%, transparent 75%);
  }
  :root[data-theme='light'] .hero__grid {
    background-image:
      linear-gradient(rgba(20,20,15,0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(20,20,15,0.08) 1px, transparent 1px);
  }
  .hero__handle {
    position: absolute;
    width: 12px; height: 12px;
    border: 2px solid var(--accent);
    background: var(--bg);
  }
  .hero__handle--tl { top: 0; left: 0; }
  .hero__handle--tr { top: 0; right: 0; }
  .hero__handle--bl { bottom: 0; left: 0; }
  .hero__handle--br { bottom: 0; right: 0; }
  .hero__avatar {
    position: relative;
    width: 100%; height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 24px 60px rgba(255, 106, 26, 0.18));
    animation: float 8s ease-in-out infinite;
  }
  @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }
  .hero__caption {
    position: absolute;
    left: 12px; bottom: 12px;
    padding: 10px 14px;
    display: flex; align-items: center; gap: 10px;
    border-radius: 10px;
    font-size: 0.76rem;
    color: var(--text-muted);
  }
  .hero__caption-line { width: 40px; height: 1px; background: var(--accent); }
  .hero__caption-scale { color: var(--accent); }

  /* Ticker */
  .ticker {
    margin-top: 30px;
    overflow: hidden;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 20px 0;
    -webkit-mask-image: linear-gradient(90deg, transparent, black 8%, black 92%, transparent);
            mask-image: linear-gradient(90deg, transparent, black 8%, black 92%, transparent);
  }
  .ticker__track {
    display: inline-flex; gap: 44px;
    white-space: nowrap;
    animation: tick 45s linear infinite;
    padding-left: 44px;
  }
  @keyframes tick { to { transform: translateX(-33.3333%); } }
  .ticker__item {
    display: inline-flex; align-items: center; gap: 14px;
    font-family: var(--font-display);
    font-size: 1.35rem;
    color: var(--text-muted);
    font-weight: 400;
    letter-spacing: -0.01em;
  }
  .ticker__dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--accent);
  }

  /* Section head */
  .section__head { max-width: 800px; margin-bottom: clamp(40px, 6vw, 72px); }

  /* Capabilities */
  .cap-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  .cap {
    padding: 32px 28px 34px;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
    position: relative;
    overflow: hidden;
    transition: border-color var(--dur) var(--ease), transform var(--dur) var(--ease);
    transition-delay: var(--stagger, 0ms);
  }
  .cap::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(80% 60% at 100% 0%, var(--accent-soft), transparent 60%);
    opacity: 0;
    transition: opacity var(--dur) var(--ease);
  }
  .cap:hover { border-color: var(--border-strong); transform: translateY(-3px); }
  .cap:hover::before { opacity: 1; }
  .cap__glyph {
    width: 44px; height: 44px;
    display: grid; place-items: center;
    border: 1px solid var(--border);
    border-radius: 12px;
    color: var(--accent);
    background: var(--accent-soft);
    margin-bottom: 22px;
    position: relative; z-index: 1;
  }
  .cap__glyph svg { width: 22px; height: 22px; }
  .cap__num {
    position: absolute;
    top: 24px; right: 26px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    letter-spacing: 0.08em;
  }
  .cap__title { font-family: var(--font-display); font-size: 1.35rem; letter-spacing: -0.015em; font-weight: 500; position: relative; z-index: 1; }
  .cap__body { color: var(--text-muted); margin-top: 12px; line-height: 1.65; font-size: 0.95rem; position: relative; z-index: 1; }

  @media (max-width: 900px) { .cap-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .cap-grid { grid-template-columns: 1fr; } }

  /* Selected work */
  .work__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 20px;
    margin-bottom: clamp(36px, 6vw, 60px);
  }
  .work__grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 20px;
  }
  .work__cell { grid-column: span 3; transition-delay: var(--stagger); }
  .work__cell--hero { grid-column: span 6; }
  @media (max-width: 900px) {
    .work__grid { grid-template-columns: 1fr 1fr; }
    .work__cell, .work__cell--hero { grid-column: span 2; }
  }
  @media (max-width: 640px) {
    .work__head { flex-direction: column; align-items: flex-start; }
    .work__grid { grid-template-columns: 1fr; }
    .work__cell, .work__cell--hero { grid-column: span 1; }
  }

  /* About preview */
  .about-prev {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: clamp(30px, 6vw, 100px);
    align-items: start;
  }
  @media (max-width: 780px) { .about-prev { grid-template-columns: 1fr; } }

  /* Final CTA */
  .finalcta {
    position: relative;
    padding: clamp(40px, 6vw, 72px);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow);
  }
  .finalcta__inner {
    display: grid;
    grid-template-columns: 1.4fr auto;
    gap: 40px;
    align-items: center;
    position: relative; z-index: 1;
  }
  .finalcta__heading {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3.8vw, 3rem);
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin: 14px 0 14px;
    font-weight: 400;
  }
  .finalcta__ctas { display: flex; flex-direction: column; gap: 10px; }
  .finalcta__decor {
    position: absolute;
    right: -40px; bottom: -40px;
    color: var(--accent);
    pointer-events: none;
  }
  @media (max-width: 780px) {
    .finalcta__inner { grid-template-columns: 1fr; }
    .finalcta__ctas { flex-direction: row; flex-wrap: wrap; }
  }

  /* Responsive hero */
  @media (max-width: 900px) {
    .hero__inner { grid-template-columns: 1fr; min-height: auto; }
    .hero__visual { justify-self: center; max-width: 420px; margin-top: 20px; }
    .hero__heading br { display: none; }
  }
  @media (max-width: 520px) {
    .hero__ctas .btn { flex: 1 1 auto; justify-content: center; }
  }
</style>
