---
import BaseLayout from '../layouts/BaseLayout.astro';
import { contact, site } from '../lib/content';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Contact provider is determined at build time from content/site.json
const provider = (site.contact_form.provider || 'auto').toLowerCase();
const formspree = site.contact_form.formspree_endpoint || '';
const web3formsKey = site.contact_form.web3forms_key || '';

let effective: 'formspree' | 'web3forms' | 'mailto' = 'mailto';
if (provider === 'formspree' && formspree) effective = 'formspree';
else if (provider === 'web3forms' && web3formsKey) effective = 'web3forms';
else if (provider === 'auto') {
  if (formspree) effective = 'formspree';
  else if (web3formsKey) effective = 'web3forms';
  else effective = 'mailto';
}

const socialLinks = [
  { label: 'Email',    value: site.email,    href: `mailto:${site.email}` },
  { label: 'LinkedIn', value: 'Connect on LinkedIn', href: site.linkedin },
  site.fiverr    && { label: 'Fiverr',    value: 'View my Fiverr',    href: site.fiverr },
  site.instagram && { label: 'Instagram', value: 'Follow on Instagram', href: site.instagram },
  site.behance   && { label: 'Behance',   value: 'View on Behance',   href: site.behance },
].filter(Boolean) as { label: string; value: string; href: string }[];
---
<BaseLayout title="Contact" description="Get in touch with Shubham Pendse for design projects, brand systems, UI/UX, presentations and creative collaborations.">
  <section class="contact-hero">
    <div class="container contact-hero__inner">
      <div class="contact-hero__text reveal">
        <span class="eyebrow">{contact.hero.eyebrow}</span>
        <h1 class="contact-hero__title">{contact.hero.heading}</h1>
        <p class="lead contact-hero__body">{contact.hero.body}</p>

        <div class="contact-hero__meta">
          <div class="cmeta">
            <span class="cmeta__label">Available</span>
            <span class="cmeta__value"><span class="cmeta__pulse" aria-hidden="true"></span>{site.availability}</span>
          </div>
          <div class="cmeta">
            <span class="cmeta__label">Based in</span>
            <span class="cmeta__value">{site.location}</span>
          </div>
          <div class="cmeta">
            <span class="cmeta__label">Response time</span>
            <span class="cmeta__value">Within 1–2 business days</span>
          </div>
        </div>
      </div>

      <aside class="contact-hero__social glass reveal">
        <span class="eyebrow" style="margin-bottom: 8px;">Elsewhere</span>
        <ul class="social-list">
          {socialLinks.map((s) => (
            <li>
              <a
                href={s.href}
                target={s.href.startsWith('http') ? '_blank' : undefined}
                rel="noopener"
                data-testid={`contact-social-${s.label.toLowerCase()}`}
              >
                <span class="social-list__label">{s.label}</span>
                <span class="social-list__value">{s.value}</span>
                <span class="social-list__arrow" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ul>
      </aside>
    </div>
  </section>

  <section class="section" id="form">
    <div class="container">
      <div class="form-wrap">
        <div class="form-lead reveal">
          <span class="eyebrow">Start a project</span>
          <h2 class="section-title">Tell me what <em>you're building</em>.</h2>
          <p class="lead">A short brief helps me reply with something useful. If your project isn't ready yet, no pressure — a message with just the idea works too.</p>
          {effective === 'mailto' && (
            <p class="text-muted" style="margin-top: 16px; font-size: 0.9rem;">
              <strong style="color: var(--accent);">Note:</strong> The direct-send provider isn't configured yet, so this form will open your email client with your message pre-filled. You can still email me directly at <a href={`mailto:${site.email}`} style="color: var(--accent);">{site.email}</a>.
            </p>
          )}
        </div>

        <form
          class="cform reveal"
          data-testid="contact-form"
          data-provider={effective}
          data-formspree={formspree}
          data-web3forms={web3formsKey}
          data-mailto={site.email}
          novalidate
        >
          <div class="cform__row cform__row--2">
            <div class="field">
              <label for="c-name">Your name</label>
              <input type="text" id="c-name" name="name" required autocomplete="name" data-testid="contact-input-name" />
            </div>
            <div class="field">
              <label for="c-email">Email</label>
              <input type="email" id="c-email" name="email" required autocomplete="email" data-testid="contact-input-email" />
            </div>
          </div>

          <div class="cform__row cform__row--2">
            <div class="field">
              <label for="c-company">Company <small>(optional)</small></label>
              <input type="text" id="c-company" name="company" autocomplete="organization" data-testid="contact-input-company" />
            </div>
            <div class="field">
              <label for="c-type">Project type</label>
              <select id="c-type" name="project_type" data-testid="contact-input-type">
                <option value="">Choose one…</option>
                {contact.project_types.map((t: string) => <option value={t}>{t}</option>)}
              </select>
            </div>
          </div>

          <div class="field">
            <label for="c-budget">Budget range <small>(optional)</small></label>
            <select id="c-budget" name="budget" data-testid="contact-input-budget">
              <option value="">Prefer not to say</option>
              {contact.budget_ranges.map((b: string) => <option value={b}>{b}</option>)}
            </select>
          </div>

          <div class="field">
            <label for="c-message">Message</label>
            <textarea id="c-message" name="message" rows="6" required placeholder="What are you working on? Any timelines or deliverables I should know about?" data-testid="contact-input-message"></textarea>
          </div>

          <!-- Honeypot -->
          <input type="text" name="_honey" tabindex="-1" autocomplete="off" style="position:absolute; left:-9999px;" aria-hidden="true" />

          <div class="cform__submit">
            <button type="submit" class="btn btn--primary" data-testid="contact-submit">
              <span data-btn-label>Send message</span>
              <span class="arrow">→</span>
            </button>
            <span class="cform__note text-dim">Or email me directly at <a href={`mailto:${site.email}`}>{site.email}</a></span>
          </div>

          <div class="cform__status" data-form-status role="status" aria-live="polite" hidden></div>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-hero { padding-top: 30px; }
  .contact-hero__inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(30px, 5vw, 60px);
    align-items: start;
    padding-top: 30px;
  }
  .contact-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5.4vw, 4.6rem);
    line-height: 1.02;
    letter-spacing: -0.03em;
    margin: 20px 0 22px;
    font-weight: 350;
  }
  .contact-hero__body { max-width: 620px; }

  .contact-hero__meta {
    display: grid;
    grid-template-columns: repeat(3, auto);
    gap: 32px;
    margin-top: 40px;
    padding: 24px 26px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }
  .cmeta { display: flex; flex-direction: column; gap: 6px; }
  .cmeta__label {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  .cmeta__value {
    display: inline-flex; align-items: center; gap: 8px;
    color: var(--text);
    font-size: 0.94rem;
  }
  .cmeta__pulse {
    width: 8px; height: 8px; border-radius: 50%;
    background: #22c55e; box-shadow: 0 0 0 4px rgba(34,197,94,0.18);
    animation: pulse 2.6s ease-out infinite;
  }
  @keyframes pulse { 0%,100% { transform: scale(1); } 50% { transform: scale(1.15); } }
  @media (max-width: 720px) {
    .contact-hero__meta { grid-template-columns: 1fr; gap: 18px; }
  }

  .contact-hero__social {
    padding: 22px 24px;
    border-radius: var(--radius-lg);
  }
  .social-list { list-style: none; }
  .social-list a {
    display: grid;
    grid-template-columns: 90px 1fr auto;
    align-items: center;
    gap: 16px;
    padding: 14px 0;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    transition: color var(--dur) var(--ease);
  }
  .social-list li:last-child a { border-bottom: 0; }
  .social-list a:hover { color: var(--accent); }
  .social-list__label { color: var(--text-dim); font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase; }
  .social-list__value { font-family: var(--font-display); font-size: 1.05rem; letter-spacing: -0.01em; }
  .social-list__arrow { color: var(--accent); }

  @media (max-width: 900px) {
    .contact-hero__inner { grid-template-columns: 1fr; }
  }

  /* Form */
  .form-wrap {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: clamp(30px, 5vw, 80px);
    align-items: start;
  }
  @media (max-width: 900px) { .form-wrap { grid-template-columns: 1fr; } }

  .cform {
    display: flex;
    flex-direction: column;
    gap: 22px;
    padding: clamp(28px, 4vw, 40px);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    position: relative;
  }
  .cform__row { display: grid; gap: 22px; }
  .cform__row--2 { grid-template-columns: 1fr 1fr; }
  @media (max-width: 560px) { .cform__row--2 { grid-template-columns: 1fr; } }

  .cform__submit {
    display: flex; align-items: center; gap: 20px; flex-wrap: wrap;
    margin-top: 8px;
  }
  .cform__note { font-size: 0.86rem; }
  .cform__note a { color: var(--accent); }

  .cform__status {
    padding: 16px 18px;
    border-radius: var(--radius);
    font-size: 0.94rem;
  }
  .cform__status.is-success {
    background: rgba(34,197,94,0.10);
    border: 1px solid rgba(34,197,94,0.4);
    color: #86efac;
  }
  .cform__status.is-error {
    background: rgba(239,68,68,0.10);
    border: 1px solid rgba(239,68,68,0.4);
    color: #fca5a5;
  }
  .cform__status.is-info {
    background: var(--accent-soft);
    border: 1px solid var(--accent);
    color: var(--accent);
  }
  .cform.is-loading .btn { pointer-events: none; opacity: 0.7; }
</style>

<script>
  const form = document.querySelector('[data-testid="contact-form"]');
  if (form) {
    const status = form.querySelector('[data-form-status]');
    const provider = form.dataset.provider || 'mailto';
    const formspree = form.dataset.formspree || '';
    const web3formsKey = form.dataset.web3forms || '';
    const mailto = form.dataset.mailto || '';
    const btnLabel = form.querySelector('[data-btn-label]');

    const setStatus = (msg, kind) => {
      kind = kind || 'info';
      if (!status) return;
      status.hidden = false;
      status.textContent = msg;
      status.classList.remove('is-success', 'is-error', 'is-info');
      status.classList.add('is-' + kind);
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      // Honeypot
      if (fd.get('_honey')) return;

      const name = (fd.get('name') || '').toString().trim();
      const email = (fd.get('email') || '').toString().trim();
      const message = (fd.get('message') || '').toString().trim();
      const company = (fd.get('company') || '').toString().trim();
      const projectType = (fd.get('project_type') || '').toString().trim();
      const budget = (fd.get('budget') || '').toString().trim();

      if (!name || !email || !message) {
        setStatus('Please fill in your name, email and message.', 'error');
        return;
      }
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        setStatus('That email looks off — mind double-checking?', 'error');
        return;
      }

      form.classList.add('is-loading');
      if (btnLabel) btnLabel.textContent = 'Sending…';
      setStatus('Sending your message…', 'info');

      try {
        if (provider === 'formspree' && formspree) {
          const res = await fetch(formspree, {
            method: 'POST',
            headers: { 'Accept': 'application/json', 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, email, company, project_type: projectType, budget, message }),
          });
          if (!res.ok) throw new Error('Formspree returned ' + res.status);
          setStatus('Message received. Let\'s create something worth showing off.', 'success');
          form.reset();
        } else if (provider === 'web3forms' && web3formsKey) {
          const payload = new FormData();
          payload.append('access_key', web3formsKey);
          payload.append('name', name);
          payload.append('email', email);
          payload.append('company', company);
          payload.append('project_type', projectType);
          payload.append('budget', budget);
          payload.append('message', message);
          payload.append('subject', `New project inquiry from ${name}`);
          const res = await fetch('https://api.web3forms.com/submit', { method: 'POST', body: payload });
          const json = await res.json();
          if (!json.success) throw new Error(json.message || 'Web3Forms failed');
          setStatus('Message received. Let\'s create something worth showing off.', 'success');
          form.reset();
        } else {
          // Mailto fallback — clearly signalled, no fake success.
          const body = [
            `Name: ${name}`,
            `Email: ${email}`,
            company && `Company: ${company}`,
            projectType && `Project type: ${projectType}`,
            budget && `Budget: ${budget}`,
            '',
            'Message:',
            message,
          ].filter(Boolean).join('\n');
          const href = `mailto:${mailto}?subject=${encodeURIComponent('New project inquiry — ' + name)}&body=${encodeURIComponent(body)}`;
          window.location.href = href;
          setStatus('Your email client is opening with the message pre-filled. Please send it from there to complete.', 'info');
        }
      } catch (err) {
        console.error(err);
        setStatus(`Something went wrong sending your message. Please email me directly at ${mailto}.`, 'error');
      } finally {
        form.classList.remove('is-loading');
        if (btnLabel) btnLabel.textContent = 'Send message';
      }
    });
  }
</script>
